{
  "resourceType": "PlanDefinition",
  "id": "aap-t21-karyotype-schedule",
  "url": "https://t21app.example.org/fhir/PlanDefinition/aap-t21-karyotype-schedule",
  "status": "active",
  "name": "AAPT21KaryotypeSchedule",
  "title": "AAP T21 Karyotype Confirmation Schedule",
  "description": "Confirm the diagnosis with a single karyotype, prenatally where possible. Done once if no prior karyotype result (full trisomy 21, translocation, or mosaic) is on record.",
  "useContext": [
    {
      "code": {
        "system": "http://terminology.hl7.org/CodeSystem/usage-context-type",
        "code": "focus"
      },
      "valueCodeableConcept": {
        "coding": [
          {
            "system": "http://snomed.info/sct",
            "code": "41040004",
            "display": "Complete trisomy 21 syndrome"
          }
        ]
      }
    }
  ],
  "type": {
    "coding": [
      {
        "system": "http://terminology.hl7.org/CodeSystem/plan-definition-type",
        "code": "protocol"
      }
    ]
  },
  "action": [
    {
      "id": "confirmatory-karyotype",
      "title": "Confirmatory Karyotype Analysis",
      "description": "Order a karyotype analysis if no prior karyotype result of any kind is recorded.",
      "definitionCanonical": "https://t21app.example.org/fhir/ActivityDefinition/t21-karyotype-analysis",
      "condition": [
        {
          "kind": "applicability",
          "expression": {
            "language": "text/fhirpath",
            "expression": "%observations.where(code.coding.where(system='http://loinc.org' and code='29770-5').exists() and valueCodeableConcept.exists()).empty()",
            "description": "Applies when no prior karyotype Observation (LOINC 29770-5) with any documented result (valueCodeableConcept) is recorded. Any resulted karyotype \u2014 full trisomy 21, translocation, or mosaic \u2014 suppresses re-ordering of a confirmatory karyotype."
          }
        }
      ],
      "timingRange": {
        "low": {
          "value": -9,
          "unit": "months",
          "system": "http://unitsofmeasure.org",
          "code": "mo"
        },
        "high": {
          "value": 0,
          "unit": "months",
          "system": "http://unitsofmeasure.org",
          "code": "mo"
        }
      }
    }
  ]
}