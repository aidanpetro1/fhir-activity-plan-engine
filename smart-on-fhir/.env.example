# Copy to .env and fill in. The app also reads plain environment variables.
# .env should NEVER be committed (add it to .gitignore).

# ---------------------------------------------------------------------------
# Data source: "local" (repo fixtures, no Epic) or "epic" (live Epic R4 + SMART)
# ---------------------------------------------------------------------------
DATA_SOURCE=local

# Flask session signing key. Generate a random one for any real deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=change-me-to-a-random-value

# ---------------------------------------------------------------------------
# Epic / SMART settings (only needed when DATA_SOURCE=epic)
# ---------------------------------------------------------------------------
# Non-production client ID from your app at https://fhir.epic.com/Developer/Apps
SMART_CLIENT_ID=

# Only if Epic issued a confidential-client secret. Public (PKCE) clients: leave blank.
SMART_CLIENT_SECRET=

# Must EXACTLY match a redirect URI registered on the Epic app.
SMART_REDIRECT_URI=http://localhost:5000/callback

# Fallback FHIR base for standalone testing. In an EHR launch Epic supplies its
# own `iss`, which overrides this. Default is Epic's public R4 sandbox:
SMART_DEFAULT_ISS=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# Space-separated SMART scopes (least-privilege; no write scope yet).
SMART_SCOPES=launch openid fhirUser offline_access patient/Patient.read patient/Observation.read patient/Procedure.read patient/Encounter.read

# Comma-separated Observation categories to fetch (Epic requires a category).
SMART_OBSERVATION_CATEGORIES=laboratory,vital-signs,social-history,exam

# Keep TLS verification on (only disable against a local mock server).
SMART_VERIFY_TLS=true

# ---------------------------------------------------------------------------
# Local demo settings (only used when DATA_SOURCE=local)
# ---------------------------------------------------------------------------
LOCAL_PATIENT=patient-1

# Server bind:
APP_HOST=127.0.0.1
APP_PORT=5000
